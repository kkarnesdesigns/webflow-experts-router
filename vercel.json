{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "ai-content-studio/api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "ai-content-studio/public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/sitemap.xml",
      "dest": "/api/sitemap.xml.js"
    },
    {
      "src": "/api/route-manifest",
      "dest": "/api/route-manifest.js"
    },
    {
      "src": "/api/generate-routes",
      "dest": "/api/generate-routes.js"
    },
    {
      "src": "/api/get-experts",
      "dest": "/api/get-experts.js"
    },
    {
      "src": "/api/dropdown-menu",
      "dest": "/api/dropdown-menu.js"
    },
    {
      "src": "/api/form-options",
      "dest": "/api/form-options.js"
    },
    {
      "src": "/api/ai-studio/collections",
      "dest": "/ai-content-studio/api/collections.js"
    },
    {
      "src": "/api/ai-studio/schema",
      "dest": "/ai-content-studio/api/schema.js"
    },
    {
      "src": "/api/ai-studio/items",
      "dest": "/ai-content-studio/api/items.js"
    },
    {
      "src": "/api/ai-studio/item-detail",
      "dest": "/ai-content-studio/api/item-detail.js"
    },
    {
      "src": "/api/ai-studio/style-guide",
      "dest": "/ai-content-studio/api/style-guide.js"
    },
    {
      "src": "/api/ai-studio/generate",
      "dest": "/ai-content-studio/api/generate.js"
    },
    {
      "src": "/api/ai-studio/save",
      "dest": "/ai-content-studio/api/save.js"
    },
    {
      "src": "/api/ai-studio/gsc-pages",
      "dest": "/ai-content-studio/api/gsc-pages.js"
    },
    {
      "src": "/ai-studio/?",
      "dest": "/ai-content-studio/public/index.html"
    },
    {
      "src": "/ai-studio/(.*)",
      "dest": "/ai-content-studio/public/$1"
    },
    {
      "src": "/client/(.*)",
      "dest": "/client/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/generate-routes",
      "schedule": "0 2 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
